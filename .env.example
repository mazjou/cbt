################################
# CARA PAKAI:
# cp .env.example .env
# nano .env   ← isi nilai yang bertanda <GANTI_INI>
################################

################################
# APPLICATION
################################
APP_NAME=lms-smkn1kras
NODE_ENV=production
PORT=3000
APP_URL=https://<DOMAIN_KAMU>
CLIENT_URL=https://<DOMAIN_KAMU>
TRUST_PROXY=1
RUN_SCHEDULER=1

################################
# SECURITY
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
################################
SESSION_SECRET=<GANTI_DENGAN_STRING_RANDOM_64_KARAKTER>
SESSION_NAME=connect.sid

################################
# DATABASE (PostgreSQL)
################################
DB_HOST=localhost
DB_PORT=5432
DB_USER=lmsuser
DB_PASSWORD=<PASSWORD_DATABASE>
DB_NAME=cbt_smk
DB_CONNECTION_LIMIT=50
DB_IDLE_TIMEOUT_MS=30000

################################
# REDIS (untuk session store - sangat disarankan di production)
################################
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<PASSWORD_REDIS>
REDIS_SESSION_PREFIX=lms:sess:
REDIS_SESSION_TTL=28800

################################
# TIMEZONE
################################
TZ=Asia/Jakarta

################################
# UPLOAD (kosongkan = pakai default src/public/uploads)
################################
UPLOAD_ROOT=

################################
# INFORMASI SEKOLAH (untuk cetak kartu peserta)
################################
SCHOOL_NAME=<NAMA_SEKOLAH>
SCHOOL_ADDRESS=<ALAMAT_SEKOLAH>
PRINCIPAL_NAME=<NAMA_KEPALA_SEKOLAH>
PRINCIPAL_NIP=<NIP_KEPALA_SEKOLAH>
