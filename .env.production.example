################################
# APPLICATION
################################
NODE_ENV=production
PORT=3000
APP_URL=https://ujian.sekolah.sch.id
CLIENT_URL=https://ujian.sekolah.sch.id
APP_NAME=lms-smkn1kras

################################
# SECURITY
################################
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=GANTI_DENGAN_STRING_RANDOM_64_KARAKTER
SESSION_NAME=lms.sid
TRUST_PROXY=1

################################
# DATABASE PostgreSQL
################################
DB_HOST=localhost
DB_PORT=5432
DB_USER=lmsuser
DB_PASSWORD=PASSWORD_KUAT_DISINI
DB_NAME=cbt_smk
DB_CONNECTION_LIMIT=30

################################
# REDIS (WAJIB untuk produksi)
################################
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=REDIS_PASSWORD_KUAT
REDIS_SESSION_PREFIX=lms:sess:
REDIS_SESSION_TTL=28800

################################
# INFORMASI SEKOLAH
################################
SCHOOL_NAME=SMK Negeri 1 Kras
SCHOOL_ADDRESS=Kediri, Jawa Timur
PRINCIPAL_NAME=Nama Kepala Sekolah
PRINCIPAL_NIP=NIP_KEPALA_SEKOLAH

################################
# TIMEZONE & UPLOAD
################################
TZ=Asia/Jakarta
UPLOAD_ROOT=/cbt/uploads

################################
# PERFORMA
################################
# Max violations anti-cheat sebelum auto-submit
ANTI_CHEAT_MAX_VIOLATIONS=5
# Auto submit middleware (1=aktif, 0=nonaktif)
AUTO_SUBMIT_MIDDLEWARE_ENABLED=1
# Jalankan scheduler auto-submit (1=aktif di 1 instance saja)
RUN_SCHEDULER=1
