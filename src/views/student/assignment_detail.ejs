<%
  const now = new Date();
  const dueDate = assignment.due_date ? new Date(assignment.due_date) : null;
  const isOverdue = dueDate && dueDate < now;
  const isSubmitted = submission !== null && submission !== undefined;
  const isGraded = isSubmitted && submission.score !== null;
  const canSubmit = !isOverdue || assignment.allow_late_submission;
%>

<div class="max-w-4xl mx-auto">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight"><%= assignment.title %></h1>
      <p class="mt-1 text-slate-600">Detail tugas dan pengumpulan.</p>
    </div>
    <a href="/student/assignments" class="px-4 py-2 bg-slate-200 hover:bg-slate-300 text-slate-700 font-medium rounded-lg">Kembali</a>
  </div>

  <!-- Info Tugas -->
  <div class="bg-white rounded-xl border border-slate-200 p-6 mb-6">
    <div class="grid grid-cols-2 gap-4 mb-4">
      <div><div class="text-xs text-slate-500">Mata Pelajaran</div><div class="font-semibold"><%= assignment.subject_name %></div></div>
      <div><div class="text-xs text-slate-500">Guru</div><div class="font-semibold"><%= assignment.teacher_name %></div></div>
      <div>
        <div class="text-xs text-slate-500">Deadline</div>
        <div class="font-semibold <%= isOverdue?'text-red-600':'' %>">
          <% if(dueDate) { %><%= dueDate.toLocaleDateString('id-ID',{day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
          <% if(isOverdue) { %><span class="text-xs bg-red-100 text-red-700 px-2 py-0.5 rounded ml-1">Terlambat</span><% } %>
          <% } else { %>Tidak ada deadline<% } %>
        </div>
      </div>
      <div><div class="text-xs text-slate-500">Nilai Maks</div><div class="font-semibold"><%= assignment.max_score %></div></div>
    </div>
    <% if(assignment.description) { %>
      <div class="pt-4 border-t border-slate-200">
        <div class="text-sm font-semibold text-slate-700 mb-2">Instruksi:</div>
        <div class="text-slate-800 bg-slate-50 rounded-lg p-4 text-sm prose prose-sm max-w-none"><%- assignment.description %></div>
      </div>
    <% } %>
  </div>

  <!-- Status Pengumpulan -->
  <% if(isSubmitted) { %>
  <div class="bg-white rounded-xl border-2 <%= isGraded?'border-green-300':'border-blue-300' %> p-6 mb-6">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 rounded-full <%= isGraded?'bg-green-100':'bg-blue-100' %> flex items-center justify-center text-xl">
        <%= isGraded?'✅':'📬' %>
      </div>
      <div>
        <div class="font-semibold"><%= isGraded?'Sudah Dinilai':'Sudah Dikumpulkan' %></div>
        <div class="text-xs text-slate-500">
          <%= new Date(submission.submitted_at).toLocaleDateString('id-ID',{day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4 mb-4">
      <div class="bg-slate-50 rounded-lg p-3">
        <div class="text-xs text-slate-500 mb-1">Pengumpulan</div>
        <% if(submission.file_path) { %>
          <a href="/public/uploads/assignments/<%= submission.file_path %>" target="_blank" class="text-blue-600 text-sm flex items-center gap-1">📄 <%= submission.file_name||'Download' %></a>
        <% } %>
        <% if(submission.link_url) { %>
          <a href="<%= submission.link_url %>" target="_blank" class="text-indigo-600 text-sm flex items-center gap-1 mt-1 break-all">🔗 Buka Link</a>
        <% } %>
        <% if(!submission.file_path && !submission.link_url) { %><span class="text-slate-400 text-sm">-</span><% } %>
      </div>
      <div class="bg-slate-50 rounded-lg p-3">
        <div class="text-xs text-slate-500 mb-1">Nilai</div>
        <% if(isGraded) { %><div class="text-2xl font-bold text-green-600"><%= submission.score %>/<%= assignment.max_score %></div>
        <% } else { %><div class="text-slate-400 text-sm">Belum dinilai</div><% } %>
      </div>
    </div>

    <% if(submission.notes) { %>
      <div class="bg-slate-50 rounded-lg p-3 mb-3">
        <div class="text-xs text-slate-500 mb-1">Catatan Anda</div>
        <div class="text-sm whitespace-pre-wrap"><%= submission.notes %></div>
      </div>
    <% } %>
    <% if(isGraded && submission.feedback) { %>
      <div class="bg-green-50 border border-green-200 rounded-lg p-3">
        <div class="text-xs font-semibold text-green-800 mb-1">Feedback Guru:</div>
        <div class="text-sm text-green-700 whitespace-pre-wrap"><%= submission.feedback %></div>
      </div>
    <% } %>
    <% if(canSubmit) { %>
      <div class="mt-4 pt-4 border-t border-slate-200">
        <button onclick="document.getElementById('uploadForm').classList.remove('hidden');this.parentElement.classList.add('hidden');"
          class="px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white font-medium rounded-lg text-sm">
          🔄 Perbarui Pengumpulan
        </button>
      </div>
    <% } %>
  </div>
  <% } %>

  <!-- Form Kumpul -->
  <div id="uploadForm" class="<%= isSubmitted?'hidden':'' %> bg-white rounded-xl border border-slate-200 p-6">
    <h3 class="text-lg font-semibold mb-4"><%= isSubmitted?'Perbarui Pengumpulan':'Kumpulkan Tugas' %></h3>

    <% if(!canSubmit) { %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-red-800 text-sm">
        ❌ Deadline sudah lewat dan pengumpulan terlambat tidak diizinkan.
      </div>
    <% } else { %>
      <form method="POST" action="/student/assignments/<%= assignment.id %>/submit" enctype="multipart/form-data" id="submitForm">
        <div class="space-y-4">

          <!-- Tab -->
          <div class="flex rounded-xl border border-slate-200 overflow-hidden">
            <button type="button" id="tab-file" onclick="switchTab('file')"
              class="flex-1 py-2.5 text-sm font-semibold bg-indigo-500 text-white">📁 Upload File</button>
            <button type="button" id="tab-link" onclick="switchTab('link')"
              class="flex-1 py-2.5 text-sm font-semibold bg-white text-slate-600 hover:bg-slate-50">🔗 Tempel Link</button>
          </div>

          <!-- Panel File -->
          <div id="panel-file">
            <input type="file" name="file" id="fileInput" accept="*/*" class="hidden" />
            <div class="border-2 border-dashed border-slate-300 rounded-lg p-6 text-center hover:border-indigo-400 transition-colors">
              <div id="uploadArea">
                <div class="text-4xl mb-2">☁️</div>
                <div class="flex flex-col sm:flex-row gap-2 justify-center">
                  <button type="button" onclick="document.getElementById('fileInput').click()"
                    class="px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white font-medium rounded-lg text-sm">📁 Pilih File</button>
                  <button type="button" onclick="openCamera()"
                    class="px-4 py-2 bg-purple-500 hover:bg-purple-600 text-white font-medium rounded-lg text-sm">📷 Ambil Foto</button>
                </div>
                <p class="mt-2 text-xs text-slate-400">Maksimal 50MB. Foto otomatis dikompress.</p>
              </div>
              <div id="previewArea" class="hidden">
                <div class="relative inline-block">
                  <img id="imagePreview" class="max-w-full max-h-48 rounded-lg shadow" />
                  <button type="button" onclick="clearFile()" class="absolute top-1 right-1 bg-red-500 text-white rounded-full w-6 h-6 text-xs">✕</button>
                </div>
                <p id="fileName" class="mt-2 text-sm font-medium text-slate-700"></p>
                <p id="fileSize" class="text-xs text-slate-400"></p>
              </div>
            </div>
          </div>

          <!-- Panel Link -->
          <div id="panel-link" class="hidden">
            <input type="url" name="link_url" id="linkInput"
              placeholder="https://drive.google.com/... atau https://youtube.com/..."
              class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
            <div class="mt-2 flex flex-wrap gap-1">
              <span class="text-xs text-slate-400">Diterima:</span>
              <span class="text-xs px-2 py-0.5 rounded-full bg-blue-100 text-blue-700">Google Drive</span>
              <span class="text-xs px-2 py-0.5 rounded-full bg-red-100 text-red-700">YouTube</span>
              <span class="text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-700">Google Docs</span>
              <span class="text-xs px-2 py-0.5 rounded-full bg-purple-100 text-purple-700">Canva</span>
              <span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 text-slate-600">Link lainnya</span>
            </div>
            <div id="link-preview" class="hidden mt-3 rounded-xl border border-indigo-200 bg-indigo-50 p-3 flex items-center gap-2">
              <span id="link-icon" class="text-xl">🔗</span>
              <div class="flex-1 min-w-0">
                <div id="link-type" class="text-xs font-semibold text-indigo-700"></div>
                <div id="link-url-display" class="text-xs text-slate-500 truncate"></div>
              </div>
              <a id="link-open" href="#" target="_blank" class="text-xs px-2 py-1 rounded-lg bg-indigo-500 text-white">Buka</a>
            </div>
          </div>

          <!-- Catatan -->
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">Catatan (Opsional)</label>
            <textarea name="notes" rows="3" placeholder="Tambahkan catatan..."
              class="w-full px-4 py-2 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 text-sm resize-none"><%= isSubmitted&&submission.notes?submission.notes:'' %></textarea>
          </div>

          <% if(isOverdue&&assignment.allow_late_submission) { %>
            <div class="bg-orange-50 border border-orange-200 rounded-lg p-3 text-sm text-orange-800">⚠️ Anda mengumpulkan setelah deadline.</div>
          <% } %>

          <div class="pt-3 border-t border-slate-200">
            <button type="submit" id="submitBtn"
              class="px-6 py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white font-semibold rounded-xl shadow-lg">
              <%= isSubmitted?'Perbarui Pengumpulan':'Kumpulkan Tugas' %>
            </button>
          </div>
        </div>
      </form>
    <% } %>
  </div>
</div>

<!-- Modal Kamera -->
<div id="cameraModal" class="fixed inset-0 z-50 hidden bg-black/75 flex items-center justify-center p-4">
  <div class="bg-white rounded-xl max-w-lg w-full p-5">
    <div class="flex justify-between mb-3">
      <h3 class="font-semibold">📷 Ambil Foto</h3>
      <button onclick="closeCamera()" class="text-slate-400 hover:text-slate-600 text-xl">✕</button>
    </div>
    <video id="cameraVideo" class="w-full rounded-lg bg-black" autoplay playsinline style="aspect-ratio:4/3;object-fit:cover;"></video>
    <canvas id="cameraCanvas" class="hidden"></canvas>
    <div class="flex gap-3 justify-center mt-4">
      <button onclick="capturePhoto()" class="px-5 py-2 bg-green-500 hover:bg-green-600 text-white font-semibold rounded-lg">📸 Ambil</button>
      <button onclick="closeCamera()" class="px-5 py-2 bg-slate-400 hover:bg-slate-500 text-white font-semibold rounded-lg">Batal</button>
    </div>
  </div>
</div>

<script>
let cameraStream = null, capturedFile = null, activeTab = 'file';

function switchTab(tab) {
  activeTab = tab;
  document.getElementById('tab-file').className = 'flex-1 py-2.5 text-sm font-semibold ' + (tab==='file'?'bg-indigo-500 text-white':'bg-white text-slate-600 hover:bg-slate-50');
  document.getElementById('tab-link').className = 'flex-1 py-2.5 text-sm font-semibold ' + (tab==='link'?'bg-indigo-500 text-white':'bg-white text-slate-600 hover:bg-slate-50');
  document.getElementById('panel-file').classList.toggle('hidden', tab!=='file');
  document.getElementById('panel-link').classList.toggle('hidden', tab!=='link');
  if(tab==='file') document.getElementById('linkInput').value='';
}

document.getElementById('linkInput').addEventListener('input', function() {
  const url = this.value.trim();
  const p = document.getElementById('link-preview');
  if(!url){p.classList.add('hidden');return;}
  let icon='🔗',type='Link';
  if(/youtube|youtu\.be/i.test(url)){icon='▶️';type='YouTube';}
  else if(/drive\.google/i.test(url)){icon='📁';type='Google Drive';}
  else if(/docs\.google/i.test(url)){icon='📄';type='Google Docs';}
  else if(/canva/i.test(url)){icon='🎨';type='Canva';}
  else if(/instagram/i.test(url)){icon='📸';type='Instagram';}
  else if(/tiktok/i.test(url)){icon='🎵';type='TikTok';}
  document.getElementById('link-icon').textContent=icon;
  document.getElementById('link-type').textContent=type;
  document.getElementById('link-url-display').textContent=url;
  document.getElementById('link-open').href=url;
  p.classList.remove('hidden');
});

document.getElementById('fileInput').addEventListener('change',function(e){if(e.target.files[0])handleFile(e.target.files[0]);});

async function handleFile(file){
  if(file.type.startsWith('image/')){const c=await compress(file);capturedFile=c;showPreview(c);}
  else{capturedFile=file;document.getElementById('fileName').textContent='📄 '+file.name;document.getElementById('fileSize').textContent=fmtSize(file.size);document.getElementById('imagePreview').classList.add('hidden');document.getElementById('uploadArea').classList.add('hidden');document.getElementById('previewArea').classList.remove('hidden');}
}

async function compress(file){return new Promise(r=>{const rd=new FileReader();rd.onload=e=>{const img=new Image();img.onload=()=>{const c=document.createElement('canvas');let w=img.width,h=img.height,m=1920;if(w>m||h>m){if(w>h){h=h/w*m;w=m;}else{w=w/h*m;h=m;}}c.width=w;c.height=h;c.getContext('2d').drawImage(img,0,0,w,h);c.toBlob(b=>r(new File([b],file.name,{type:'image/jpeg'})),'image/jpeg',0.85);};img.src=e.target.result;};rd.readAsDataURL(file);});}

function showPreview(file){const rd=new FileReader();rd.onload=e=>{document.getElementById('imagePreview').src=e.target.result;document.getElementById('imagePreview').classList.remove('hidden');document.getElementById('fileName').textContent=file.name;document.getElementById('fileSize').textContent=fmtSize(file.size)+' (terkompress)';document.getElementById('uploadArea').classList.add('hidden');document.getElementById('previewArea').classList.remove('hidden');};rd.readAsDataURL(file);}

function clearFile(){capturedFile=null;document.getElementById('fileInput').value='';document.getElementById('uploadArea').classList.remove('hidden');document.getElementById('previewArea').classList.add('hidden');document.getElementById('imagePreview').classList.remove('hidden');}

function fmtSize(b){if(!b)return'0 B';const k=1024,s=['B','KB','MB','GB'],i=Math.floor(Math.log(b)/Math.log(k));return(b/Math.pow(k,i)).toFixed(1)+' '+s[i];}

async function openCamera(){try{cameraStream=await navigator.mediaDevices.getUserMedia({video:{facingMode:'environment'}});document.getElementById('cameraVideo').srcObject=cameraStream;document.getElementById('cameraModal').classList.remove('hidden');}catch(e){alert('Tidak dapat mengakses kamera.');}}

function closeCamera(){if(cameraStream){cameraStream.getTracks().forEach(t=>t.stop());cameraStream=null;}document.getElementById('cameraModal').classList.add('hidden');}

async function capturePhoto(){const v=document.getElementById('cameraVideo'),c=document.getElementById('cameraCanvas');c.width=v.videoWidth;c.height=v.videoHeight;c.getContext('2d').drawImage(v,0,0);c.toBlob(async b=>{const f=new File([b],`foto_${Date.now()}.jpg`,{type:'image/jpeg'});capturedFile=await compress(f);showPreview(capturedFile);closeCamera();},'image/jpeg',0.85);}

document.getElementById('submitForm').addEventListener('submit',function(e){
  const link=document.getElementById('linkInput').value.trim();
  if(activeTab==='link'){
    if(!link){e.preventDefault();alert('Masukkan link tugas.');return;}
    try{new URL(link);}catch(_){e.preventDefault();alert('Link tidak valid. Harus diawali https://');return;}
    return;
  }
  if(capturedFile){
    e.preventDefault();
    const fd=new FormData(this);fd.delete('file');fd.append('file',capturedFile);
    const btn=document.getElementById('submitBtn');btn.disabled=true;btn.textContent='Mengunggah...';
    fetch(this.action,{method:'POST',body:fd}).then(r=>{window.location.href=r.url||window.location.href;}).catch(()=>{alert('Gagal mengunggah.');btn.disabled=false;btn.textContent='Kumpulkan Tugas';});
  } else if(!document.getElementById('fileInput').files[0]){
    e.preventDefault();alert('Pilih file atau masukkan link tugas.');
  }
});
</script>
