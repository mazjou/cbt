<script>
const cpuHistory = [], ramHistory = [], labels = [];
const MAX_POINTS = 12; // 12 × 5 detik = 60 detik

function fmt(bytes) {
  if (bytes >= 1024) return (bytes/1024).toFixed(1) + ' GB';
  return bytes + ' MB';
}
function fmtUptime(sec) {
  const d = Math.floor(sec/86400), h = Math.floor((sec%86400)/3600),
        m = Math.floor((sec%3600)/60), s = Math.floor(sec%60);
  if (d > 0) return `${d}h ${h}j ${m}m`;
  if (h > 0) return `${h}j ${m}m ${s}d`;
  return `${m}m ${s}d`;
}
function colorBar(pct) {
  if (pct >= 80) return 'bg-red-500';
  if (pct >= 60) return 'bg-amber-500';
  return 'bg-blue-500';
}

async function downloadBackup(btn) {
  const log = document.getElementById('backup-log');
  const origText = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '⏳ Memproses...';
  log.className = 'mt-3 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm font-medium text-amber-700';
  log.textContent = '⏳ Membuat backup database, harap tunggu...';
  log.classList.remove('hidden');

  try {
    const r = await fetch('/admin/monitoring/backup-db');
    if (!r.ok) {
      const d = await r.json().catch(() => ({ message: r.statusText }));
      log.className = 'mt-3 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700';
      log.textContent = '❌ Gagal: ' + (d.message || 'Error tidak diketahui');
      return;
    }
    // Trigger download
    const blob = await r.blob();
    const cd = r.headers.get('Content-Disposition') || '';
    const fnMatch = cd.match(/filename="?([^"]+)"?/);
    const filename = fnMatch ? fnMatch[1] : `backup_${Date.now()}.sql`;
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = filename; a.click();
    URL.revokeObjectURL(url);
    log.className = 'mt-3 rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm font-medium text-green-700';
    log.textContent = `✅ Backup berhasil didownload: ${filename}`;
  } catch(e) {
    log.className = 'mt-3 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700';
    log.textContent = '❌ Gagal: ' + e.message;
  } finally {
    btn.disabled = false;
    btn.innerHTML = origText;
  }
}

async function restartService(service, btn) {
  const labels = { app: 'Aplikasi', postgresql: 'PostgreSQL', redis: 'Redis' };
  const label = labels[service] || service;

  if (!confirm(`Yakin ingin restart ${label}?\n\nPastikan tidak ada siswa yang sedang ujian!`)) return;

  const log = document.getElementById('restart-log');
  const origText = btn.textContent;
  btn.disabled = true;
  btn.textContent = '⏳ Memproses...';
  log.className = 'mt-3 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm font-medium text-amber-700';
  log.textContent = `⏳ Mengirim perintah restart ${label}...`;
  log.classList.remove('hidden');

  try {
    const r = await fetch('/admin/monitoring/restart', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ service })
    });
    const d = await r.json();

    if (d.ok) {
      log.className = 'mt-3 rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm font-medium text-green-700';
      log.textContent = `✅ ${d.message}`;
      // Refresh data setelah 3 detik
      setTimeout(fetchData, 3000);
    } else {
      log.className = 'mt-3 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700';
      log.textContent = `❌ ${d.message}`;
    }
  } catch(e) {
    log.className = 'mt-3 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700';
    log.textContent = `❌ Gagal: ${e.message}`;
  } finally {
    btn.disabled = false;
    btn.textContent = origText;
  }
}

async function fetchData() {
  try {
    const r = await fetch('/admin/monitoring/data');
    const d = await r.json();
    if (!d.ok) return;

    const s = d.server, db = d.db, st = d.stats;

    // Status bar
    document.getElementById('status-bar').className = 'mb-4 rounded-xl px-4 py-2 text-sm font-medium bg-green-50 border border-green-200 text-green-700';
    document.getElementById('status-bar').textContent = '✅ Server Online — ' + new Date(d.timestamp).toLocaleString('id-ID');
    document.getElementById('last-update').textContent = 'Update: ' + new Date().toLocaleTimeString('id-ID');

    // Tampilkan info host service
    const isLocal = (h) => !h || h === 'localhost' || h === '127.0.0.1';
    if (d.serviceHosts) {
      const dbLabel = document.getElementById('db-host-label');
      const redisLabel = document.getElementById('redis-host-label');
      if (dbLabel) dbLabel.textContent = isLocal(d.serviceHosts.db)
        ? 'Server lokal'
        : '🌐 Remote: ' + d.serviceHosts.db;
      if (redisLabel) redisLabel.textContent = isLocal(d.serviceHosts.redis)
        ? 'Server lokal'
        : '🌐 Remote: ' + d.serviceHosts.redis;
    }

    // CPU
    const cpuPct = s.cpuUsage;
    document.getElementById('cpu-pct').textContent = cpuPct + '%';
    const cpuBar = document.getElementById('cpu-bar');
    cpuBar.style.width = cpuPct + '%';
    cpuBar.className = 'h-full rounded-full transition-all duration-700 ' + colorBar(cpuPct);
    document.getElementById('cpu-val').textContent = cpuPct + '%';
    document.getElementById('cpu-cores').textContent = s.cpuCores + ' core';

    // RAM - tampilkan RAM proses Node.js (RSS), bukan RAM sistem
    const maxRam = 512; // anggap max 512MB untuk bar (bisa disesuaikan)
    const ramPct = Math.min(Math.round(s.nodeRss / maxRam * 100), 100);
    document.getElementById('ram-pct').textContent = fmt(s.nodeRss) + ' RSS / ' + fmt(s.heapUsed) + ' Heap';
    const ramBar = document.getElementById('ram-bar');
    ramBar.style.width = ramPct + '%';
    ramBar.className = 'h-full rounded-full transition-all duration-700 ' + (ramPct >= 80 ? 'bg-red-500' : ramPct >= 60 ? 'bg-amber-500' : 'bg-emerald-500');
    document.getElementById('ram-val').textContent = fmt(s.nodeRss);
    document.getElementById('ram-detail').textContent = 'Heap: ' + fmt(s.heapUsed) + ' / ' + fmt(s.heapTotal);

    // Uptime
    document.getElementById('uptime-os').textContent = fmtUptime(s.uptimeOs);
    document.getElementById('uptime-app').textContent = fmtUptime(s.uptimeApp);
    document.getElementById('node-ver').textContent = s.nodeVersion;
    document.getElementById('platform').textContent = s.platform + ' ' + s.arch;
    document.getElementById('srv-status').className = 'ml-auto text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-700 font-semibold';
    document.getElementById('srv-status').textContent = '● Online';

    // DB
    document.getElementById('db-active').textContent = db.active;
    document.getElementById('db-total').textContent = db.total;
    document.getElementById('db-uptime').textContent = db.uptime;
    document.getElementById('db-size').textContent = d.dbSize;
    document.getElementById('db-status').className = 'ml-auto text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-700 font-semibold';
    document.getElementById('db-status').textContent = '● Connected';

    // Stats
    document.getElementById('stat-users').textContent = st.users;
    document.getElementById('stat-exams').textContent = st.exams;
    document.getElementById('stat-attempts').textContent = st.attempts;
    document.getElementById('stat-active').textContent = st.activeAttempts;

    // Checklist kesiapan
    const chk = (id, ok, warn) => {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = ok ? '✅' : (warn ? '⚠️' : '❌');
    };
    chk('chk-db', true);
    chk('chk-ram', s.nodeRss < 300, s.nodeRss < 400);
    chk('chk-cpu', cpuPct < 70, cpuPct < 85);
    chk('chk-conn', db.active < 20, db.active < 25);
    chk('chk-active', st.activeAttempts === 0, st.activeAttempts < 10);
    const chkActiveCount = document.getElementById('chk-active-count');
    if (chkActiveCount) chkActiveCount.textContent = st.activeAttempts;
    // Redis: dari data server
    const redisOk = d.redisConnected === true;
    document.getElementById('chk-redis').textContent = redisOk ? '✅' : '⚠️';

    const allOk = s.nodeRss < 300 && cpuPct < 70 && db.active < 20;
    const msg = document.getElementById('readiness-msg');
    if (allOk) {
      msg.className = 'mt-3 text-sm font-semibold text-green-700';
      msg.textContent = '✅ Server siap untuk ujian massal';
    } else {
      msg.className = 'mt-3 text-sm font-semibold text-amber-700';
      msg.textContent = '⚠️ Perhatikan item yang belum hijau sebelum memulai ujian massal';
    }
    document.getElementById('proc-pid').textContent = s.pid || '-';
    document.getElementById('proc-heap').textContent = fmt(s.heapUsed || 0);
    document.getElementById('proc-heap-total').textContent = fmt(s.heapTotal || 0);
    document.getElementById('proc-rss').textContent = fmt(s.rss || 0);
    document.getElementById('proc-host').textContent = s.hostname;

    // RAM Sistem
    const ramSysPct = s.memPercent || 0;
    const ramSysColor = ramSysPct >= 85 ? 'bg-red-500' : ramSysPct >= 70 ? 'bg-amber-500' : 'bg-sky-500';
    document.getElementById('ram-sys-bar').style.width = ramSysPct + '%';
    document.getElementById('ram-sys-bar').className = 'h-full rounded-full transition-all duration-700 ' + ramSysColor;
    document.getElementById('ram-sys-label').textContent = fmt(s.usedMem) + ' / ' + fmt(s.totalMem);
    document.getElementById('ram-sys-pct-badge').textContent = ramSysPct + '%';
    document.getElementById('ram-sys-pct-badge').className = 'ml-auto text-xs px-2 py-0.5 rounded-full font-semibold ' +
      (ramSysPct >= 85 ? 'bg-red-100 text-red-700' : ramSysPct >= 70 ? 'bg-amber-100 text-amber-700' : 'bg-sky-100 text-sky-700');
    document.getElementById('ram-sys-used').textContent = fmt(s.usedMem);
    document.getElementById('ram-sys-free').textContent = fmt(s.freeMem);
    document.getElementById('ram-sys-total').textContent = fmt(s.totalMem);
    // Node RSS bar (relatif terhadap total RAM sistem)
    const nodeRssPct = s.totalMem > 0 ? Math.min(Math.round(s.nodeRss / s.totalMem * 100), 100) : 0;
    document.getElementById('ram-node-bar').style.width = nodeRssPct + '%';
    document.getElementById('ram-node-label').textContent = fmt(s.nodeRss) + ' RSS (' + nodeRssPct + '% dari total)';

    // Storage
    const stor = d.storage || {};
    const diskPct = stor.percent || 0;
    const diskColor = diskPct >= 85 ? 'bg-red-500' : diskPct >= 70 ? 'bg-amber-500' : 'bg-orange-500';
    document.getElementById('disk-bar').style.width = diskPct + '%';
    document.getElementById('disk-bar').className = 'h-full rounded-full transition-all duration-700 ' + diskColor;
    document.getElementById('disk-label').textContent = (stor.used || 0) + ' MB / ' + (stor.total || 0) + ' MB';
    document.getElementById('disk-pct-badge').textContent = diskPct + '%';
    document.getElementById('disk-pct-badge').className = 'ml-auto text-xs px-2 py-0.5 rounded-full font-semibold ' +
      (diskPct >= 85 ? 'bg-red-100 text-red-700' : diskPct >= 70 ? 'bg-amber-100 text-amber-700' : 'bg-orange-100 text-orange-700');
    const fmtMb = v => v >= 1024 ? (v/1024).toFixed(1)+' GB' : (v||0)+' MB';
    document.getElementById('disk-used').textContent = fmtMb(stor.used);
    document.getElementById('disk-free').textContent = fmtMb(stor.free);
    document.getElementById('disk-total').textContent = fmtMb(stor.total);
    document.getElementById('disk-uploads').textContent = stor.uploadSize || '-';

    // Tabel siswa sedang ujian - ringkasan per ujian
    const activeExams = d.activeExams || [];
    const totalActive = d.stats?.activeAttempts || 0;
    const badge = document.getElementById('active-count-badge');
    badge.textContent = totalActive;
    badge.className = 'ml-1 px-2 py-0.5 rounded-full text-xs font-bold ' +
      (totalActive > 0 ? 'bg-green-100 text-green-700' : 'bg-slate-100 text-slate-500');

    if (activeExams.length === 0) {
      document.getElementById('active-exams-empty').classList.remove('hidden');
      document.getElementById('active-exams-table').classList.add('hidden');
    } else {
      document.getElementById('active-exams-empty').classList.add('hidden');
      document.getElementById('active-exams-table').classList.remove('hidden');
      const tbody = document.getElementById('active-exams-tbody');
      tbody.innerHTML = activeExams.map(a => {
        const duration = a.duration_minutes || 0;
        const maxElapsed = a.max_elapsed || 0;
        const remaining = a.remaining_minutes || 0;
        const progress = duration > 0 ? Math.min(Math.round(maxElapsed / duration * 100), 100) : 0;
        const progressColor = remaining <= 5 ? 'bg-red-500' : remaining <= 15 ? 'bg-amber-500' : 'bg-green-500';
        const remainingText = remaining <= 0
          ? '<span class="text-red-600 font-bold">Habis</span>'
          : `<span class="${remaining <= 5 ? 'text-red-600 font-bold' : remaining <= 15 ? 'text-amber-600 font-semibold' : 'text-green-700'}">${remaining} mnt</span>`;
        return `<tr class="border-b border-slate-100 hover:bg-slate-50">
          <td class="py-2 px-3 font-semibold text-slate-800 text-sm">${a.exam_title}</td>
          <td class="py-2 px-3 text-center">
            <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-green-100 text-green-700 font-bold text-lg">${a.student_count}</span>
          </td>
          <td class="py-2 px-3 text-center text-sm text-slate-600">${duration} mnt</td>
          <td class="py-2 px-3 text-center text-sm text-slate-600">${a.min_elapsed}–${maxElapsed} mnt</td>
          <td class="py-2 px-3 text-center">${remainingText}</td>
          <td class="py-2 px-3 text-center">
            <div class="flex items-center gap-2">
              <div class="flex-1 h-2 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full rounded-full ${progressColor}" style="width:${progress}%"></div>
              </div>
              <span class="text-xs text-slate-500 w-8">${progress}%</span>
            </div>
          </td>
        </tr>`;
      }).join('');
    }

    // Chart history
    const now = new Date().toLocaleTimeString('id-ID', {hour:'2-digit',minute:'2-digit',second:'2-digit'});
    labels.push(now);
    cpuHistory.push(cpuPct);
    ramHistory.push(ramPct);
    if (labels.length > MAX_POINTS) { labels.shift(); cpuHistory.shift(); ramHistory.shift(); }
    drawChart();

  } catch(e) {
    document.getElementById('status-bar').className = 'mb-4 rounded-xl px-4 py-2 text-sm font-medium bg-red-50 border border-red-200 text-red-700';
    document.getElementById('status-bar').textContent = '❌ Gagal memuat data: ' + e.message;
  }
}

// Simple canvas chart
function drawChart() {
  const canvas = document.getElementById('chart-cpu');
  const ctx = canvas.getContext('2d');
  const W = canvas.offsetWidth, H = canvas.offsetHeight;
  canvas.width = W; canvas.height = H;
  ctx.clearRect(0, 0, W, H);

  if (cpuHistory.length < 2) return;

  const pad = { t:10, r:10, b:24, l:36 };
  const cW = W - pad.l - pad.r, cH = H - pad.t - pad.b;

  // Grid
  ctx.strokeStyle = '#f1f5f9'; ctx.lineWidth = 1;
  [0,25,50,75,100].forEach(v => {
    const y = pad.t + cH - (v/100)*cH;
    ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(pad.l+cW, y); ctx.stroke();
    ctx.fillStyle = '#94a3b8'; ctx.font = '10px Arial';
    ctx.fillText(v+'%', 0, y+4);
  });

  function drawLine(data, color) {
    ctx.beginPath(); ctx.strokeStyle = color; ctx.lineWidth = 2;
    data.forEach((v, i) => {
      const x = pad.l + (i/(MAX_POINTS-1))*cW;
      const y = pad.t + cH - (v/100)*cH;
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    });
    ctx.stroke();
    // Fill
    ctx.lineTo(pad.l + ((data.length-1)/(MAX_POINTS-1))*cW, pad.t+cH);
    ctx.lineTo(pad.l, pad.t+cH);
    ctx.closePath();
    ctx.fillStyle = color.replace(')', ',0.1)').replace('rgb','rgba');
    ctx.fill();
  }

  drawLine(cpuHistory, 'rgb(99,102,241)');
  drawLine(ramHistory, 'rgb(16,185,129)');

  // Legend
  ctx.fillStyle = 'rgb(99,102,241)'; ctx.fillRect(pad.l, H-14, 12, 4);
  ctx.fillStyle = '#475569'; ctx.font = '10px Arial'; ctx.fillText('CPU', pad.l+16, H-10);
  ctx.fillStyle = 'rgb(16,185,129)'; ctx.fillRect(pad.l+60, H-14, 12, 4);
  ctx.fillStyle = '#475569'; ctx.fillText('RAM', pad.l+76, H-10);
}

// Auto refresh setiap 5 detik
fetchData();
setInterval(fetchData, 5000);
</script>
