<div class="flex items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-indigo-900">🔑 Preview Import Password</h1>
    <p class="mt-1 text-sm text-slate-500">Cek data sebelum password diupdate</p>
  </div>
  <div class="flex gap-2">
    <a href="/admin/users/import-password" class="px-4 py-2 rounded-xl border border-slate-200 hover:bg-slate-100 text-sm">← Upload Ulang</a>
    <a href="/admin/users" class="px-4 py-2 rounded-xl border border-slate-200 hover:bg-slate-100 text-sm">Batal</a>
  </div>
</div>

<%- include('../partials/flash') %>

<div class="grid lg:grid-cols-3 gap-4">

  <!-- Ringkasan & Tombol Simpan -->
  <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
    <div class="text-lg font-semibold mb-3">Ringkasan</div>
    <div class="grid grid-cols-2 gap-3 mb-4">
      <div class="rounded-xl bg-white border border-green-200 p-3 text-center">
        <div class="text-2xl font-bold text-green-700"><%= preview.length %></div>
        <div class="text-xs text-green-600">Akan diupdate</div>
      </div>
      <div class="rounded-xl bg-white border border-red-200 p-3 text-center">
        <div class="text-2xl font-bold text-red-600"><%= errors.length %></div>
        <div class="text-xs text-red-500">Dilewati/Error</div>
      </div>
    </div>

    <form action="/admin/users/import-password/commit" method="POST">
      <input type="hidden" name="importId" value="<%= importId %>" />
      <button class="w-full rounded-xl bg-emerald-500 hover:bg-emerald-400 text-white font-semibold py-3 transition-all <%= preview.length?'':'opacity-50 cursor-not-allowed' %>"
        <%= preview.length?'':'disabled' %>>
        ✅ Update <%= preview.length %> Password
      </button>
    </form>

    <% if (!preview.length) { %>
      <div class="mt-2 text-xs text-amber-600">Tidak ada data valid.</div>
    <% } %>

    <div class="mt-4 p-3 rounded-xl bg-amber-50 border border-amber-200 text-xs text-amber-700">
      ⚠️ Password akan langsung diupdate setelah klik tombol. Tindakan ini tidak bisa dibatalkan.
    </div>
  </div>

  <!-- Preview Data Valid -->
  <div class="lg:col-span-2 rounded-2xl border border-slate-200 bg-slate-50 p-5">
    <div class="text-lg font-semibold mb-3">Data yang Akan Diupdate</div>

    <% if (!preview.length) { %>
      <div class="rounded-xl bg-white border border-slate-200 p-4 text-slate-500 text-sm">Tidak ada data valid.</div>
    <% } else { %>
    <div class="overflow-x-auto max-h-80 overflow-y-auto">
      <table class="w-full text-sm">
        <thead class="sticky top-0 bg-slate-100">
          <tr class="text-left text-xs text-slate-500 border-b border-slate-200">
            <th class="py-2 px-3">No</th>
            <th class="py-2 px-3">Username</th>
            <th class="py-2 px-3">Password Baru</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% preview.forEach((p, i) => { %>
          <tr class="bg-white hover:bg-slate-50">
            <td class="py-2 px-3 text-slate-400 text-xs"><%= p.rowNo %></td>
            <td class="py-2 px-3 font-mono text-slate-800 text-xs"><%= p.username %></td>
            <td class="py-2 px-3">
              <span class="font-mono bg-green-50 border border-green-200 text-green-800 px-2 py-0.5 rounded text-xs"><%= p.password %></span>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>

    <!-- Error list -->
    <% if (errors.length) { %>
    <div class="mt-4">
      <div class="text-sm font-semibold text-red-700 mb-2">⚠️ Dilewati (<%= errors.length %>):</div>
      <div class="space-y-1 max-h-40 overflow-y-auto">
        <% errors.forEach(e => { %>
        <div class="text-xs text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-1.5">
          Baris <%= e.rowNo %>: <%= e.reason %>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>
</div>
