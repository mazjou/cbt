<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:Arial,sans-serif;background:#e5e7eb;}

    /* Kontrol */
    .no-print{
      background:white;padding:12px 20px;
      display:flex;align-items:center;justify-content:space-between;
      flex-wrap:wrap;gap:10px;box-shadow:0 2px 6px rgba(0,0,0,.12);margin-bottom:14px;
    }
    .no-print h2{font-size:15px;color:#1e293b;}
    .no-print small{color:#64748b;font-size:12px;}
    .ctrl{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
    .btn{padding:7px 16px;border-radius:7px;font-weight:600;font-size:13px;
         cursor:pointer;border:none;text-decoration:none;display:inline-flex;align-items:center;gap:5px;}
    .btn-print{background:#4f46e5;color:white;}
    .btn-back{background:#f1f5f9;color:#475569;}
    select.fs{padding:6px 12px;border-radius:7px;border:2px solid #e2e8f0;font-size:13px;color:#475569;background:white;}

    /* Halaman A4 Portrait: 2 kolom × 4 baris = 8 kartu */
    .page{
      width:210mm;
      height:297mm;
      margin:0 auto 16px;
      background:white;
      padding:5mm 5mm;
      display:grid;
      grid-template-columns:repeat(2,1fr);
      grid-template-rows:repeat(4,1fr);
      gap:3mm;
    }

    /* Kartu: ~97mm × 66mm */
    .kartu{
      border:1.5px solid #1e3a8a;
      display:flex;
      flex-direction:column;
      overflow:hidden;
      page-break-inside:avoid;
      background:white;
    }

    /* ── HEADER ── */
    .k-head{
      display:flex;
      align-items:stretch;
      border-bottom:1.5px solid #1e3a8a;
      background:#eff6ff;
      flex-shrink:0;
      height:12mm;
    }
    .k-logo{
      width:12mm;flex-shrink:0;
      display:flex;align-items:center;justify-content:center;
      border-right:1px solid #1e3a8a;padding:1mm;
    }
    .k-logo img{width:9mm;height:9mm;object-fit:contain;}
    .k-title{
      flex:1;display:flex;flex-direction:column;
      align-items:center;justify-content:center;
      padding:0.5mm 1mm;text-align:center;
    }
    .k-title .t1{font-size:8pt;font-weight:bold;text-transform:uppercase;color:#1e3a8a;letter-spacing:.2px;}
    .k-title .t2{font-size:7.5pt;font-weight:bold;color:#1e3a8a;margin-top:0.5px;}
    .k-title .t3{font-size:6.5pt;color:#374151;margin-top:0.5px;}
    .k-panitia{
      width:12mm;flex-shrink:0;
      border-left:1px solid #1e3a8a;
      display:flex;align-items:center;justify-content:center;
      font-size:6.5pt;font-weight:bold;color:#1e3a8a;
      text-align:center;padding:1mm;
    }

    /* ── BODY ── */
    .k-body{
      flex:1;
      display:flex;
      flex-direction:column;
      padding:1.5mm 2.5mm 1mm;
      overflow:hidden;
      gap:1.5mm;
    }

    /* Baris atas: data full width */
    .k-info{ width:100%; }
    .dt{width:100%;border-collapse:collapse;}
    .dt td{font-size:8pt;padding:0.6mm 0;vertical-align:top;color:#111827;line-height:1.3;}
    .dt .lb{width:22mm;color:#111827;white-space:nowrap;font-size:8pt;}
    .dt .sp{width:4mm;text-align:left;padding-left:1mm;}
    .dt .vl{font-weight:normal;font-size:8pt;}
    .dt .mono{font-family:'Courier New',monospace;font-size:7.5pt;}

    /* Baris bawah: foto kiri | TTD tengah | QR kanan */
    .k-bottom{
      display:flex;
      align-items:flex-end;
      gap:2mm;
    }
    .foto-box{
      width:17mm;height:20mm;
      border:1px solid #374151;
      display:flex;align-items:center;justify-content:center;
      background:#f9fafb;overflow:hidden;flex-shrink:0;
    }
    .foto-box img{width:100%;height:100%;object-fit:cover;}
    .foto-ph{font-size:5pt;color:#9ca3af;text-align:center;line-height:1.3;}

    .ttd{
      flex:1;
      font-size:8pt;color:#111827;line-height:1.6;
      display:flex;flex-direction:column;align-items:flex-start;justify-content:center;
      text-align:left;
    }
    .ttd .garis{border-bottom:1px solid #111827;width:30mm;margin:3mm 0 0.5mm;}
    .ttd .tnama{font-weight:bold;font-size:8pt;}
    .ttd .tnip{font-size:7pt;}

    .qr-wrap{
      width:16mm;height:16mm;
      display:flex;align-items:center;justify-content:center;
      flex-shrink:0;
    }
    .qr-label{font-size:4pt;color:#6b7280;text-align:center;margin-top:0.5mm;}

    /* Footer */
    .k-foot{
      border-top:1px solid #e5e7eb;
      padding:0.8mm 2mm;text-align:center;
      font-size:5pt;color:#6b7280;background:#f9fafb;flex-shrink:0;
    }

    /* ── PRINT ── */
    @media print{
      body{background:white;}
      .no-print{display:none;}
      .page{
        margin:0;padding:5mm;
        width:210mm;height:297mm;
        page-break-after:always;
      }
      .page:last-child{page-break-after:auto;}
      @page{size:A4 portrait;margin:0;}
    }
  </style>
</head>
<body>

<!-- Kontrol -->
<div class="no-print">
  <div>
    <h2>🖨️ Cetak Kartu Peserta</h2>
    <small><%= users.length %> kartu • A4 Portrait • 8 kartu/halaman</small>
  </div>
  <div class="ctrl">
    <form method="GET" action="/admin/users/print-cards" style="display:flex;gap:8px;">
      <select name="role" class="fs" onchange="this.form.submit()">
        <option value="">Semua Role</option>
        <option value="TEACHER" <%=role==='TEACHER'?'selected':''%>>Guru</option>
        <option value="STUDENT" <%=role==='STUDENT'?'selected':''%>>Siswa</option>
      </select>
      <select name="class_id" class="fs" onchange="this.form.submit()">
        <option value="">Semua Kelas</option>
        <%if(typeof classes!=='undefined')classes.forEach(c=>{%>
          <option value="<%=c.id%>" <%=class_id==c.id?'selected':''%>><%=c.name%></option>
        <%});%>
      </select>
    </form>
    <button onclick="window.print()" class="btn btn-print">🖨️ Cetak</button>
    <a href="/admin/users" class="btn btn-back">← Kembali</a>
  </div>
</div>

<%
  const tahunAjaran=(()=>{const y=new Date().getFullYear();return new Date().getMonth()>=6?`${y}/${y+1}`:`${y-1}/${y}`;})();
  const tglCetak=new Date().toLocaleDateString('id-ID',{day:'numeric',month:'long',year:'numeric'});
  const appUrl=(process.env.APP_URL||'localhost:3000').replace(/^https?:\/\//,'');
  const PERHAL=8;
%>

<%for(let p=0;p<users.length;p+=PERHAL){%>
<div class="page">
  <%for(let j=p;j<Math.min(p+PERHAL,users.length);j++){
    const u=users[j];
    const isSiswa=u.role==='STUDENT';
    // Nomor peserta: pakai nomor_peserta jika ada, kosong jika tidak ada
    const noPeserta=u.nomor_peserta || null;
  %>
  <div class="kartu">

    <!-- Header -->
    <div class="k-head">
      <div class="k-logo">
        <img src="/public/images/logo.png" alt="Logo"
             onerror="this.outerHTML='<span style=\'font-size:14pt\'>🎓</span>'">
      </div>
      <div class="k-title">
        <div class="t1">Kartu Peserta Ujian</div>
        <div class="t2"><%=schoolInfo.name%></div>
        <div class="t3">Tahun Pelajaran <%=tahunAjaran%></div>
      </div>
      <div class="k-panitia">Panitia</div>
    </div>

    <!-- Body: Data atas full width, foto+TTD+QR bawah -->
    <div class="k-body">

      <!-- ATAS: Data full width -->
      <div class="k-info">
        <table class="dt">
          <%if(noPeserta){%>
          <tr><td class="lb">No Peserta</td><td class="sp">:</td><td class="vl"><%=noPeserta%></td></tr>
          <%}%>
          <tr><td class="lb">Nama</td><td class="sp">:</td><td class="vl"><%=u.full_name%></td></tr>
          <%if(u.class_name){%>
          <tr><td class="lb">Kelas</td><td class="sp">:</td><td class="vl"><%=u.class_name%></td></tr>
          <%}%>
          <tr><td class="lb">Username</td><td class="sp">:</td><td class="vl mono"><%=u.username%></td></tr>
          <tr><td class="lb">Password</td><td class="sp">:</td><td class="vl mono"><%=u.plain_password || u.username%></td></tr>
        </table>
      </div>

      <!-- BAWAH: Foto kiri | TTD tengah | QR kanan -->
      <div class="k-bottom">
        <!-- Foto -->
        <div>
          <div class="foto-box">
            <%
              // Validasi path foto - hanya tampilkan jika path valid (bukan URL eksternal/404)
              const fotoSrc = u.profile_photo && u.profile_photo.startsWith('/public/') ? u.profile_photo : null;
            %>
            <%if(fotoSrc){%>
              <img src="<%=fotoSrc%>" alt="Foto" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
              <div class="foto-ph" style="display:none;">📷<br>Foto<br>Peserta</div>
            <%}else{%>
              <div class="foto-ph">📷<br>Foto<br>Peserta</div>
            <%}%>
          </div>
        </div>

        <!-- TTD -->
        <div class="ttd">
          <div><%=schoolInfo.address%>, <%=tglCetak%></div>
          <div>Kepala Sekolah,</div>
          <div class="garis"></div>
          <div class="tnama"><%=process.env.PRINCIPAL_NAME||'Kepala Sekolah'%></div>
          <div class="tnip">NIP. <%=process.env.PRINCIPAL_NIP||'-'%></div>
        </div>

        <!-- QR kanan bawah -->
        <div style="text-align:center;">
          <div class="qr-wrap" id="qr-<%=j%>"></div>
          <div class="qr-label">Scan login</div>
        </div>
      </div>

    </div>

    <!-- Footer -->
    <div class="k-foot">Simpan kartu ini • Jangan bagikan kepada orang lain</div>
  </div>
  <%}%>
</div>
<%}%>

<script>
(function(){
  var s=document.createElement('script');
  s.src='https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js';
  s.onload=function(){
    <%for(let j=0;j<users.length;j++){
      const u=users[j];
      const qrText=(process.env.APP_URL||'http://localhost:3000')+'|'+u.username;
    %>
    try{new QRCode(document.getElementById('qr-<%=j%>'),{
      text:'<%-qrText.replace(/\\/g,"\\\\").replace(/'/g,"\\'")%>',
      width:58,height:58,colorDark:'#000',colorLight:'#fff',
      correctLevel:QRCode.CorrectLevel.M
    });}catch(e){}
    <%}%>
  };
  s.onerror=function(){
    document.querySelectorAll('[id^="qr-"]').forEach(function(el){
      el.style.cssText='font-size:6pt;text-align:center;padding:3mm;color:#9ca3af;';
      el.textContent='QR';
    });
  };
  document.head.appendChild(s);
})();
</script>
</body>
</html>
