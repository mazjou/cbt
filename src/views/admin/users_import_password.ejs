<div class="flex items-center justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-indigo-900">🔑 Import Update Password</h1>
    <p class="mt-1 text-sm text-slate-500">Update password banyak pengguna sekaligus via file Excel</p>
  </div>
  <a href="/admin/users" class="px-4 py-2 rounded-xl border border-indigo-200 bg-indigo-50 hover:bg-indigo-100 text-indigo-800 font-medium text-sm">← Kembali</a>
</div>

<%- include('../partials/flash') %>

<div class="grid lg:grid-cols-2 gap-5">

  <!-- Panduan -->
  <div class="rounded-2xl border border-blue-200 bg-gradient-to-br from-blue-50 to-blue-100 p-6">
    <h2 class="font-bold text-blue-900 mb-4">📋 Panduan</h2>
    <ol class="text-sm text-blue-800 space-y-3">
      <li class="flex gap-2"><span class="text-blue-500 font-bold">1.</span><span>Download template Excel di bawah</span></li>
      <li class="flex gap-2"><span class="text-blue-500 font-bold">2.</span>
        <div>Isi kolom:
          <div class="mt-1 font-mono text-xs bg-white px-2 py-1 rounded border border-blue-200 inline-block">username, password_baru</div>
        </div>
      </li>
      <li class="flex gap-2"><span class="text-blue-500 font-bold">3.</span><span>Upload file → Preview → Konfirmasi</span></li>
      <li class="flex gap-2"><span class="text-blue-500 font-bold">4.</span><span>Password minimal 4 karakter</span></li>
      <li class="flex gap-2"><span class="text-blue-500 font-bold">5.</span><span>Username yang tidak ditemukan akan dilewati</span></li>
    </ol>
    <div class="mt-5 flex gap-2">
      <a href="/public/templates/update_password_template.xlsx"
        class="flex-1 px-4 py-3 rounded-xl bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white font-semibold text-sm text-center transition-all">
        📥 Download Template Excel
      </a>
    </div>
  </div>

  <!-- Form Upload -->
  <div class="rounded-2xl border border-purple-200 bg-gradient-to-br from-purple-50 to-purple-100 p-6">
    <h2 class="font-bold text-purple-900 mb-4">📤 Upload File</h2>
    <form action="/admin/users/import-password/preview" method="POST" enctype="multipart/form-data" class="space-y-4">
      <div>
        <label class="text-sm text-purple-700 font-medium">File Excel (.xlsx)</label>
        <input type="file" name="file" accept=".xlsx,.csv" required
          class="mt-2 w-full rounded-xl bg-white border-2 border-purple-200 px-4 py-3 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-purple-100 file:text-purple-700 hover:file:bg-purple-200" />
      </div>
      <button class="w-full rounded-xl bg-gradient-to-r from-purple-500 to-purple-600 hover:from-purple-600 hover:to-purple-700 text-white font-semibold py-3 transition-all">
        ✨ Preview & Validasi
      </button>
    </form>
  </div>
</div>
