<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-900">🔒 Siswa Terkunci</h1>
    <p class="text-sm text-slate-500 mt-1">Siswa yang layarnya terkunci karena pelanggaran. Generate token untuk membuka kunci.</p>
  </div>
  <a href="/teacher/grades" class="px-4 py-2 rounded-xl border border-slate-200 hover:bg-slate-100 text-sm font-medium">← Kembali</a>
</div>

<% if (!locked || locked.length === 0) { %>
  <div class="rounded-2xl border border-green-200 bg-green-50 p-10 text-center">
    <div class="text-4xl mb-3">✅</div>
    <div class="font-semibold text-green-800">Tidak ada siswa yang terkunci saat ini</div>
    <div class="text-sm text-green-600 mt-1">Semua siswa dapat mengerjakan ujian dengan normal</div>
  </div>
<% } else { %>
  <div class="rounded-2xl border border-red-200 bg-white shadow-sm overflow-hidden">
    <div class="bg-red-50 px-5 py-3 border-b border-red-200 flex items-center gap-2">
      <span class="text-red-600 font-bold text-lg"><%= locked.length %></span>
      <span class="text-sm text-red-700 font-medium">siswa terkunci</span>
      <span class="ml-auto text-xs text-slate-400">Token berlaku sampai siswa memasukkan dengan benar</span>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
          <tr>
            <th class="text-left py-3 px-4 text-xs font-semibold text-slate-500 uppercase">Siswa</th>
            <th class="text-left py-3 px-4 text-xs font-semibold text-slate-500 uppercase">Kelas</th>
            <th class="text-left py-3 px-4 text-xs font-semibold text-slate-500 uppercase">Ujian</th>
            <th class="text-center py-3 px-4 text-xs font-semibold text-slate-500 uppercase">Pelanggaran</th>
            <th class="text-center py-3 px-4 text-xs font-semibold text-slate-500 uppercase">Terkunci Sejak</th>
            <th class="text-center py-3 px-4 text-xs font-semibold text-slate-500 uppercase">Dibuka</th>
            <th class="text-center py-3 px-4 text-xs font-semibold text-slate-500 uppercase">Token</th>
            <th class="text-center py-3 px-4 text-xs font-semibold text-slate-500 uppercase">Aksi</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% locked.forEach(row => { %>
          <tr class="hover:bg-red-50 transition-colors">
            <td class="py-3 px-4">
              <div class="font-semibold text-slate-800"><%= row.student_name %></div>
              <div class="text-xs text-slate-400"><%= row.username %></div>
            </td>
            <td class="py-3 px-4 text-slate-600"><%= row.class_name || '-' %></td>
            <td class="py-3 px-4 text-slate-700 max-w-xs truncate" title="<%= row.exam_title %>"><%= row.exam_title %></td>
            <td class="py-3 px-4 text-center">
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-red-100 text-red-700 font-bold text-sm">
                <%= row.violation_count %>
              </span>
            </td>
            <td class="py-3 px-4 text-center text-xs text-slate-500">
              <%= row.locked_at ? new Date(row.locked_at).toLocaleString('id-ID') : '-' %>
            </td>
            <td class="py-3 px-4 text-center text-xs text-slate-500">
              <% if (row.unlock_count > 0) { %>
                <span class="px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 font-semibold"><%= row.unlock_count %>x dibuka</span>
              <% } else { %>
                <span class="text-slate-400">Belum pernah</span>
              <% } %>
            </td>
            <td class="py-3 px-4 text-center">
              <span id="token-<%= row.attempt_id %>"
                class="inline-block px-3 py-1 rounded-lg bg-slate-100 text-slate-700 font-mono font-bold text-sm tracking-widest">
                <%= row.unlock_token || '------' %>
              </span>
            </td>
            <td class="py-3 px-4 text-center">
              <button onclick="generateToken(<%= row.attempt_id %>)"
                class="px-3 py-1.5 rounded-lg bg-indigo-500 hover:bg-indigo-600 text-white text-xs font-semibold transition-all">
                Generate Token Baru
              </button>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<div class="mt-6 rounded-2xl border border-blue-200 bg-blue-50 p-5">
  <div class="font-semibold text-blue-900 mb-2">Cara Membuka Kunci Siswa:</div>
  <ol class="text-sm text-blue-800 space-y-1 list-decimal list-inside">
    <li>Klik <strong>Generate Token Baru</strong> untuk siswa yang terkunci</li>
    <li>Token 6 karakter akan muncul di kolom Token</li>
    <li>Sampaikan token tersebut ke siswa secara langsung (lisan atau tulis di papan)</li>
    <li>Siswa memasukkan token di layar terkunci mereka</li>
    <li>Layar otomatis terbuka dan siswa bisa melanjutkan ujian</li>
  </ol>
  <div class="mt-3 text-xs text-blue-600">
    Halaman ini auto-refresh setiap 15 detik. Token lama tidak berlaku setelah generate token baru.
  </div>
</div>

<script>
async function generateToken(attemptId) {
  const btn = event.target;
  const origText = btn.textContent;
  btn.disabled = true;
  btn.textContent = '⏳...';
  // Deteksi apakah di admin atau teacher dari URL
  const base = window.location.pathname.startsWith('/admin') ? '/admin' : '/teacher';
  try {
    const r = await fetch(`${base}/violations/unlock/${attemptId}`, { method: 'POST' });
    const d = await r.json();
    if (d.ok) {
      const el = document.getElementById(`token-${attemptId}`);
      if (el) {
        el.textContent = d.token;
        el.className = 'inline-block px-3 py-1 rounded-lg bg-green-100 text-green-800 font-mono font-bold text-sm tracking-widest animate-pulse';
        setTimeout(() => {
          el.className = 'inline-block px-3 py-1 rounded-lg bg-yellow-100 text-yellow-800 font-mono font-bold text-sm tracking-widest';
        }, 3000);
      }
    } else {
      alert('Gagal: ' + d.message);
    }
  } catch(e) {
    alert('Error: ' + e.message);
  } finally {
    btn.disabled = false;
    btn.textContent = origText;
  }
}

// Auto-refresh setiap 15 detik
setTimeout(() => location.reload(), 15000);
</script>
