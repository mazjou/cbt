<div class="flex items-start justify-between gap-4 mb-6">
  <div>
    <div class="text-sm text-slate-500">Preview Import Word</div>
    <h1 class="text-2xl font-bold text-indigo-900"><%= exam.title || 'Ujian' %></h1>
    <p class="mt-1 text-slate-600">Cek hasil parsing Word sebelum disimpan ke database.</p>
  </div>
  <div class="flex gap-2">
    <a href="/teacher/exams/<%= examId %>/import" class="px-4 py-2 rounded-xl border border-slate-200 hover:bg-slate-100 text-sm">← Kembali</a>
    <a href="/teacher/exams/<%= examId %>" class="px-4 py-2 rounded-xl bg-indigo-500 hover:bg-indigo-400 text-white font-semibold text-sm">Ujian</a>
  </div>
</div>

<%- include('../partials/flash') %>

<div class="grid lg:grid-cols-3 gap-4">

  <!-- Ringkasan & Tombol Simpan -->
  <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
    <div class="text-lg font-semibold mb-3">Ringkasan</div>
    <div class="grid grid-cols-2 gap-3 text-sm mb-4">
      <div class="rounded-xl bg-white border border-green-200 p-3 text-center">
        <div class="text-2xl font-bold text-green-700"><%= preview.length %></div>
        <div class="text-xs text-green-600">Soal valid</div>
      </div>
      <div class="rounded-xl bg-white border border-red-200 p-3 text-center">
        <div class="text-2xl font-bold text-red-600"><%= errors.length %></div>
        <div class="text-xs text-red-500">Perlu dibenahi</div>
      </div>
    </div>

    <% const withQImg = preview.filter(q => q.question_image).length %>
    <% const withOptImg = preview.filter(q => Object.values(q.option_images||{}).some(v=>v)).length %>
    <div class="text-xs text-slate-500 space-y-1 mb-4">
      <div>📷 Soal bergambar: <span class="font-semibold text-slate-700"><%= withQImg %></span></div>
      <div>🖼️ Opsi bergambar: <span class="font-semibold text-slate-700"><%= withOptImg %></span> soal</div>
    </div>

    <form action="/teacher/exams/<%= examId %>/questions/import/commit" method="POST">
      <input type="hidden" name="importId" value="<%= importId %>" />
      <button class="w-full rounded-xl bg-emerald-500 hover:bg-emerald-400 text-white font-semibold py-3 transition-all <%= preview.length ? '' : 'opacity-50 cursor-not-allowed' %>" <%= preview.length ? '' : 'disabled' %>>
        ✅ Simpan <%= preview.length %> Soal
      </button>
    </form>

    <% if (!preview.length) { %>
      <div class="mt-2 text-xs text-amber-600">Tidak ada soal valid. Perbaiki format Word lalu upload ulang.</div>
    <% } %>

    <!-- Format panduan -->
    <details class="mt-4">
      <summary class="cursor-pointer text-xs text-indigo-600 font-medium">📖 Format Word yang didukung</summary>
      <pre class="mt-2 text-xs bg-white border border-slate-200 rounded-xl p-3 whitespace-pre-wrap text-slate-700 font-mono">1. Teks soal di sini
[gambar soal bisa di baris berikutnya]
A. Opsi A
[gambar opsi A bisa di baris berikutnya]
B. Opsi B
C. Opsi C
D. Opsi D
E. Opsi E
KUNCI: B
NILAI: 2

2. Soal berikutnya...
A. ...
...</pre>
    </details>
  </div>

  <!-- Preview Soal Valid -->
  <div class="lg:col-span-2 rounded-2xl border border-slate-200 bg-slate-50 p-5">
    <div class="text-lg font-semibold mb-1">Preview Soal Valid</div>
    <div class="text-sm text-slate-500 mb-4">Menampilkan hingga 10 soal pertama</div>

    <% if (!preview.length) { %>
      <div class="rounded-xl bg-white border border-slate-200 p-4 text-slate-500">Tidak ada soal valid.</div>
    <% } else { %>
    <div class="space-y-4 max-h-[600px] overflow-y-auto pr-1">
      <% preview.slice(0,10).forEach((q, i) => { %>
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <div class="flex items-center justify-between gap-2 mb-2">
          <span class="text-xs text-slate-400">Soal <%= q.rowNo %> • Poin <%= q.points %></span>
          <span class="text-xs px-2 py-0.5 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-700 font-semibold">Kunci: <%= q.correct %></span>
        </div>

        <!-- Teks soal -->
        <div class="text-slate-800 text-sm whitespace-pre-wrap"><%= q.question_text %></div>

        <!-- Gambar soal -->
        <% if (q.question_image) { %>
        <div class="mt-2">
          <img src="<%= q.question_image %>" alt="Gambar soal" class="max-h-48 rounded-xl border border-slate-200 object-contain" />
        </div>
        <% } %>

        <!-- Opsi jawaban -->
        <div class="mt-3 grid grid-cols-1 gap-2">
          <% ['A','B','C','D','E'].forEach(lbl => { %>
          <div class="rounded-xl border <%= lbl === q.correct ? 'border-emerald-300 bg-emerald-50' : 'border-slate-200 bg-slate-50' %> p-2 flex items-start gap-2">
            <span class="text-xs font-bold <%= lbl === q.correct ? 'text-emerald-700' : 'text-slate-500' %> w-5 shrink-0 mt-0.5"><%= lbl %>.</span>
            <div class="flex-1 min-w-0">
              <% if (q.options[lbl]) { %>
                <div class="text-sm text-slate-700"><%= q.options[lbl] %></div>
              <% } %>
              <% if (q.option_images && q.option_images[lbl]) { %>
                <img src="<%= q.option_images[lbl] %>" alt="Gambar opsi <%= lbl %>" class="mt-1 max-h-24 rounded-lg border border-slate-200 object-contain" />
              <% } %>
              <% if (!q.options[lbl] && !(q.option_images && q.option_images[lbl])) { %>
                <span class="text-xs text-slate-400 italic">kosong</span>
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% }) %>
      <% if (preview.length > 10) { %>
        <div class="text-center text-sm text-slate-400 py-2">... dan <%= preview.length - 10 %> soal lainnya</div>
      <% } %>
    </div>
    <% } %>
  </div>
</div>

<!-- Error list -->
<% if (errors.length) { %>
<div class="mt-4 rounded-2xl border border-red-200 bg-red-50 p-5">
  <div class="text-lg font-semibold text-red-800 mb-3">⚠️ Soal yang Gagal Diparse (<%= errors.length %>)</div>
  <div class="space-y-2">
    <% errors.slice(0,20).forEach(e => { %>
    <div class="rounded-xl bg-white border border-red-200 p-3">
      <div class="text-xs font-semibold text-red-600 mb-1">Soal #<%= e.rowNo %></div>
      <ul class="text-xs text-red-700 list-disc pl-4 space-y-0.5">
        <% (e.reasons||[]).forEach(r => { %><li><%= r %></li><% }) %>
      </ul>
      <% if (e.snapshot?.question_text) { %>
        <div class="mt-1 text-xs text-slate-500 truncate">Teks: <%= e.snapshot.question_text.slice(0,80) %></div>
      <% } %>
    </div>
    <% }) %>
  </div>
</div>
<% } %>
