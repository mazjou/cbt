<div class="flex items-start justify-between gap-4 mb-6">
  <div>
    <h1 class="text-3xl font-bold text-indigo-900">Preview Import Bank Soal</h1>
    <p class="mt-1 text-slate-600">Cek hasil parsing sebelum disimpan ke bank soal.</p>
  </div>
  <a href="/teacher/question-bank/import" class="px-4 py-2 rounded-xl border border-slate-200 hover:bg-slate-100 font-medium">← Upload Ulang</a>
</div>

<div class="grid lg:grid-cols-3 gap-5">
  <!-- Ringkasan & Commit -->
  <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
    <div class="text-lg font-semibold mb-3">Ringkasan</div>
    <div class="grid grid-cols-2 gap-3 text-sm mb-4">
      <div class="rounded-xl bg-white border border-emerald-200 p-3 text-center">
        <div class="text-slate-500 text-xs">Valid</div>
        <div class="text-2xl font-bold text-emerald-600"><%= preview.length %></div>
      </div>
      <div class="rounded-xl bg-white border border-red-200 p-3 text-center">
        <div class="text-slate-500 text-xs">Error</div>
        <div class="text-2xl font-bold text-red-500"><%= errors.length %></div>
      </div>
    </div>

    <form action="/teacher/question-bank/import/commit" method="POST" class="space-y-3">
      <input type="hidden" name="importId" value="<%= importId %>" />

      <!-- Pilih mapel default untuk soal yang tidak punya kolom subject -->
      <% const noSubject = preview.filter(p => !p.subject_id); %>
      <% if (noSubject.length > 0) { %>
        <div class="rounded-xl bg-amber-50 border border-amber-200 p-3">
          <div class="text-xs font-semibold text-amber-800 mb-1">⚠️ <%= noSubject.length %> soal tidak punya mata pelajaran</div>
          <label class="text-xs text-amber-700 block mb-1">Pilih mapel default:</label>
          <select name="default_subject_id" required
            class="w-full rounded-lg border border-amber-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-400">
            <option value="">-- Pilih Mapel --</option>
            <% subjects.forEach(s => { %>
              <option value="<%= s.id %>"><%= s.name %></option>
            <% }) %>
          </select>
        </div>
      <% } %>

      <button type="submit" <%= preview.length ? '' : 'disabled' %>
        class="w-full rounded-xl bg-emerald-500 hover:bg-emerald-600 disabled:opacity-50 text-white font-bold py-3 transition-all">
        💾 Simpan ke Bank Soal
      </button>
      <% if (!preview.length) { %>
        <p class="text-xs text-red-500 text-center">Tidak ada soal valid. Perbaiki file lalu upload ulang.</p>
      <% } %>
    </form>
  </div>

  <!-- Preview Soal Valid -->
  <div class="lg:col-span-2 rounded-2xl border border-slate-200 bg-slate-50 p-5">
    <div class="flex items-center justify-between mb-3">
      <div class="text-lg font-semibold">Preview Soal Valid</div>
      <div class="text-sm text-slate-500">Menampilkan 10 pertama dari <%= preview.length %> soal</div>
    </div>

    <% if (!preview.length) { %>
      <div class="rounded-xl bg-white border border-slate-200 p-4 text-slate-500 text-sm">Tidak ada soal valid.</div>
    <% } else { %>
      <div class="space-y-3 max-h-[60vh] overflow-y-auto pr-1">
        <% preview.slice(0, 10).forEach((q, i) => { %>
          <div class="rounded-xl border border-slate-200 bg-white p-4">
            <div class="flex items-center justify-between gap-2 mb-2">
              <div class="text-xs text-slate-500">Baris <%= q.rowNo %> • <%= q.points %> poin • <span class="font-medium"><%= q.difficulty %></span><% if (q.subjectRaw) { %> • <%= q.subjectRaw %><% } %></div>
              <span class="px-2 py-0.5 rounded-full bg-indigo-100 text-indigo-700 text-xs font-bold">Kunci: <%= q.correct %></span>
            </div>
            <div class="text-sm text-slate-900 mb-2"><%= q.question_text %></div>
            <div class="grid grid-cols-2 gap-1.5 text-xs">
              <% ['A','B','C','D','E'].forEach(lbl => { %>
                <div class="rounded-lg px-2 py-1.5 <%= lbl === q.correct ? 'bg-emerald-100 border border-emerald-300 font-semibold text-emerald-800' : 'bg-slate-100 text-slate-700' %>">
                  <span class="font-bold"><%= lbl %>.</span> <%= q.options[lbl] %>
                </div>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<% if (errors.length) { %>
  <div class="mt-5 rounded-2xl border border-red-200 bg-red-50 p-5">
    <div class="text-lg font-semibold text-red-800 mb-3">❌ Baris yang Gagal (<%= errors.length %>)</div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-slate-500 border-b border-red-200">
            <th class="py-2 pr-4">Baris</th>
            <th class="py-2 pr-4">Masalah</th>
            <th class="py-2">Soal</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-red-100">
          <% errors.slice(0, 30).forEach(e => { %>
            <tr>
              <td class="py-2 pr-4 font-mono text-xs"><%= e.rowNo %></td>
              <td class="py-2 pr-4 text-red-700 text-xs"><%= (e.reasons || []).join('; ') %></td>
              <td class="py-2 text-slate-600 text-xs truncate max-w-xs"><%= e.snapshot?.question_text || '-' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
